# ─────────────────────────────────────────────────
# TalentIQ — Environment Variables Template
# Copy to .env and fill in real values.
# NEVER commit the filled .env file.
# ─────────────────────────────────────────────────

# ── PostgreSQL (Neon or Railway Postgres) ─────────
DATABASE_URL="postgres://user:password@host:5432/talentiq"

# ── Anthropic (Claude 3) ──────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Cloudflare R2 (video storage) ─────────────────
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_ACCOUNT_ID="..."          # your Cloudflare account ID (not API token)
R2_BUCKET_NAME="alfaleus-interviews"

# ── Resend (email invitations) ────────────────────
RESEND_API_KEY="re_..."

# ── Auth (Better Auth) ────────────────────────────
BETTER_AUTH_SECRET="a-random-64-char-string"
JWT_SECRET="another-random-secret"

# ── Inter-service URLs (set to Railway service URLs in production) ─────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
SCRAPER_WORKER_URL="http://localhost:8001"
JD_ANALYSIS_WORKER_URL="http://localhost:8002"
SCORER_WORKER_URL="http://localhost:8003"
TRANSCRIBER_WORKER_URL="http://localhost:8004"

# ── Optional: local Postgres overrides ───────────
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="talentiq"
